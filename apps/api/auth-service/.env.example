PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=fuel_pass_auth
DB_SSL=false
# DB_TYPE=sqlite
# SQLITE_DATABASE=:memory:
# SQLITE_SYNCHRONIZE=true

JWT_ISSUER=fuelpass-auth
JWT_AUDIENCE=fuelpass-api
JWT_ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7
JWT_KEY_ID=fuelpass-auth-dev-1
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-rs256-private-key\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nreplace-with-rs256-public-key\n-----END PUBLIC KEY-----"
BCRYPT_ROUNDS=12
INTERNAL_SERVICE_API_KEY=replace-with-internal-service-api-key
