{
    "extends": "@fuel-pass/typescript-config/backend",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "emitDeclarationOnly": false,
        "types": [
            "node",
            "jest"
        ],
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "out-tsc",
        "dist",
        "jest.config.js"
    ]
}