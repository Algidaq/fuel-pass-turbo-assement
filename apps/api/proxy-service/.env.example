PORT=3100
NODE_ENV=development
LOG_LEVEL=info
HEALTH_TIMEOUT_MS=2000

AUTH_SERVICE_URL=http://localhost:3000
AUTH_SERVICE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
AUTH_SERVICE_HEALTH_PATH=/api/health

ORDERS_SERVICE_URL=http://localhost:3001
ORDERS_SERVICE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
ORDERS_SERVICE_HEALTH_PATH=/api/health

