# ORDERS SERVICE ENVS
ORDERS-PORT=3001
ORDERS-NODE_ENV=development
ORDERS-CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:5173

ORDERS-DB_TYPE=postgres
ORDERS-DB_HOST=localhost
ORDERS-DB_PORT=5433
ORDERS-DB_USERNAME=postgres
ORDERS-DB_PASSWORD=postgres
ORDERS-DB_DATABASE=fuel_pass_orders
ORDERS-DB_SSL=false
# SQLite alternative for apps/api/orders-service/.env:
# ORDERS-DB_TYPE=sqlite
# ORDERS-SQLITE_DATABASE=./orders.sqlite
# ORDERS-SQLITE_SYNCHRONIZE=true

ORDERS-AUTH_INTERNAL_BASE_URL=http://localhost:3000/api/internal/auth
ORDERS-AUTH_INTROSPECTION_TIMEOUT_MS=3000
ORDERS-INTERNAL_SERVICE_API_KEY=dev-internal-auth-key

# PROXY SERVICE ENVS
PROXY-PORT=3100
PROXY-NODE_ENV=development
PROXY-LOG_LEVEL=debug
PROXY-HEALTH_TIMEOUT_MS=2000

PROXY-AUTH_SERVICE_URL=http://localhost:3000
PROXY-AUTH_SERVICE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
PROXY-AUTH_SERVICE_HEALTH_PATH=/api/health

PROXY-ORDERS_SERVICE_URL=http://localhost:3001
PROXY-ORDERS_SERVICE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
PROXY-ORDERS_SERVICE_HEALTH_PATH=/api/health

# WEB APP ENVS
WEB-VITE_API_BASE_URL=http://localhost:3100
