{
    "name": "@fuel-pass/ui",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./styles.css": "./dist/styles.css"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json && mkdir -p dist && cp src/styles/theme.css dist/styles.css && rsync -a --include='*/' --include='*.module.css' --exclude='*' src/ dist/",
        "dev": "tsc -p tsconfig.build.json --watch",
        "clean": "rm -rf dist",
        "lint": "eslint .",
        "lint:fix": "eslint --fix",
        "check-types": "tsc -p tsconfig.json --noEmit",
        "test": "echo \"No tests configured for @fuel-pass/ui\""
    },
    "peerDependencies": {
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@fuel-pass/eslint-config": "*",
        "@fuel-pass/typescript-config": "*",
        "@types/react": "19.2.2",
        "@types/react-dom": "19.2.2",
        "eslint": "^9.39.1",
        "typescript": "5.9.2"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/material": "^9.2.0",
        "tslib": "^2.3.0"
    }
}
