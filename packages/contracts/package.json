{
    "name": "@fuel-pass/contracts",
    "version": "0.0.1",
    "private": true,
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": {
                "types": "./dist/esm/index.d.ts",
                "default": "./dist/esm/index.js"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            },
            "default": "./dist/esm/index.js"
        },
        "./backend": {
            "import": {
                "types": "./dist/esm/backend.d.ts",
                "default": "./dist/esm/backend.js"
            },
            "require": {
                "types": "./dist/cjs/backend.d.ts",
                "default": "./dist/cjs/backend.js"
            },
            "default": "./dist/esm/backend.js"
        }
    },
    "scripts": {
        "build": "npm run clean && tsc -p tsconfig.build.esm.json && tsc -p tsconfig.build.cjs.json && node ./scripts/write-package-types.cjs",
        "dev": "tsc -p tsconfig.build.json --watch",
        "clean": "rm -rf dist",
        "lint": "eslint .",
        "lint:fix": "eslint --fix",
        "test": "jest",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "@fuel-pass/eslint-config": "*",
        "@fuel-pass/node-commons": "*",
        "@fuel-pass/typescript-config": "*",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "reflect-metadata": "^0.2.2",
        "tslib": "^2.3.0",
        "zod": "^4.4.3"
    }
}
