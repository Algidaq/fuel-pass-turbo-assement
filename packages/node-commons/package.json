        "class-transformer": "^0.5.1",
        "compression": "^1.8.1",
        "helmet": "^8.2.0",
        "morgan": "^1.11.0",
        "nocache": "^4.0.0",
        "p-retry": "^4.6.2",
        "pino-http": "^11.0.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/compression": "^1.8.1",
        "@types/helmet": "^0.0.48",
        "@types/morgan": "^1.9.10"
    }
