# DOCKER POSTGRES ENVS
POSTGRES_HOST_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# AUTH SERVICE ENVS
AUTH-PORT=3000
AUTH-NODE_ENV=development
AUTH-CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# DB Env
AUTH-DB_TYPE=postgres
AUTH-DB_HOST=localhost
AUTH-DB_PORT=5433
AUTH-DB_USERNAME=postgres
AUTH-DB_PASSWORD=postgres
AUTH-DB_DATABASE=fuel_pass_auth
AUTH-DB_SSL=false
# SQLite alternative for apps/api/auth-service/.env:
# AUTH-DB_TYPE=sqlite
# AUTH-SQLITE_DATABASE=./auth.sqlite
# AUTH-SQLITE_SYNCHRONIZE=true

