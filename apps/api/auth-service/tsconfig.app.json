{
    "extends": "../../../tsconfig.backend.json",
    "compilerOptions": {
        "outDir": "dist",
        "emitDeclarationOnly": false,
        "types": ["node"],
        "rootDir": "src",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    },
    "include": ["src/**/*.ts"],
    "exclude": [
        "out-tsc",
        "dist",
        "jest.config.ts",
        "jest.config.cts",
        "tests/**/*.spec.ts",
        "tests/**/*.test.ts",
        "eslint.config.js",
        "eslint.config.cjs",
        "eslint.config.mjs",
        "webpack.config.js"
    ],
    "references": [
        {
            "path": "../../../libs/contracts/tsconfig.lib.json"
        },
        {
            "path": "../../../libs/node-commons/tsconfig.lib.json"
        }
    ]
}
